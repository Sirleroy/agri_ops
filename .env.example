# ── Core ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# setup.sh generates this automatically — never use a guessable value in production.
SECRET_KEY=replace-with-generated-key

# config.settings.development | config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────────
# Option A — individual vars (local development)
DB_NAME=agri_ops_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Option B — connection URL (Render, Heroku, CI — overrides individual vars above if set)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email (production only — development uses console backend) ─────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@agriops.io

# ── Monitoring (production only) ───────────────────────────────────────────────
# Leave blank in development — Sentry is only initialised when DJANGO_SETTINGS_MODULE=config.settings.production
SENTRY_DSN=
